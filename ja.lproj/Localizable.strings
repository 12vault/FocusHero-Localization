"hero_quote_first_john_author" = "ヨハネの手紙一 4:19";
"hero_quote_jeremiah_text" = "わたしはあなたがたのために立てている計画を知っている。… それは災いではなく平安を与え、将来と希望を与える計画である。";
"hero_quote_jeremiah_author" = "エレミヤ書 29:11";
"hero_quote_psalm_text" = "たとえ死の陰の谷を歩むことがあっても、私はわざわいを恐れない。あなたが私と共におられるからだ。";
